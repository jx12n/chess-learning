{
  "band": "the-basics",
  "title": "The Basics",
  "complete": "Seven days. Six pieces. One whole army. You can name every square, slide rooks and bishops, sweep the queen everywhere, hop the knight over anything, march pawns into queens, walk the king safely — and always grab the best prize. Your next adventure — check and checkmate — is coming soon. And chess never runs out of adventures!",
  "days": [
    {
      "day": 1,
      "title": "The Board & The Rook",
      "nodes": ["board-orientation", "rook-movement", "rook-capture"],
      "wrapUp": "You can name any square, march a rook down its lines, and gobble everything in its path.",
      "teaser": "Next: the bishop — the diagonal slider is waiting."
    },
    {
      "day": 2,
      "title": "The Bishop",
      "nodes": ["bishop-movement", "bishop-capture"],
      "wrapUp": "Diagonals are yours — and you know a bishop keeps its color forever.",
      "teaser": "Next: the queen — a rook and a bishop wearing one crown."
    },
    {
      "day": 3,
      "title": "The Queen",
      "nodes": ["queen-movement", "queen-capture"],
      "wrapUp": "Straight AND diagonal — you steered the strongest piece on the board.",
      "teaser": "Next: the knight — the only piece that can JUMP."
    },
    {
      "day": 4,
      "title": "The Knight",
      "nodes": ["knight-movement", "knight-capture"],
      "wrapUp": "L-shaped hops, right over the crowd — the trickiest piece is yours now.",
      "teaser": "Next: the pawn — small, brave, and full of dreams."
    },
    {
      "day": 5,
      "title": "The Pawn",
      "nodes": ["pawn-march", "pawn-capture"],
      "wrapUp": "March straight, munch sideways — and you turned a little pawn into a QUEEN.",
      "teaser": "Next: the king — the most important piece of all."
    },
    {
      "day": 6,
      "title": "The King",
      "nodes": ["king-movement", "king-capture"],
      "wrapUp": "One careful step at a time — you walked the king like a true bodyguard.",
      "teaser": "Tomorrow is the big finish of your first week: the whole army together, and how to pick the best prize!"
    },
    {
      "day": 7,
      "title": "Values & The Whole Army",
      "nodes": ["piece-values", "the-whole-army"],
      "wrapUp": "You know what every piece is worth, and your pieces work as a team.",
      "teaser": "Next adventure: check and checkmate — coming soon."
